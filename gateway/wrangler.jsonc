{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "pda-ai-gateway",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-22",
  "workers_dev": true,
  "d1_databases": [
    { "binding": "DB", "database_name": "pda-ai-gateway", "database_id": "766a56ff-89fe-4763-9e29-95c43927f6df" }
  ],
  "triggers": { "crons": ["17 3 * * *"] },
  "vars": {
    "OPENAI_MODEL": "gpt-5-nano-2025-08-07",
    "PHASE1_GLOBAL_USD_PER_DAY": "0.25",
    "OPENAI_BALANCE_ESTIMATE_USD": "0"
  }
}
